# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# API-FOOTBALL (api-sports) — NEVER expose to the browser; server/cron only
# Direct subscription: set API_FOOTBALL_KEY and leave RAPIDAPI vars empty
API_FOOTBALL_KEY=
# Optional RapidAPI mode
API_FOOTBALL_RAPIDAPI_HOST=v3.football.api-sports.io
API_FOOTBALL_RAPIDAPI_KEY=

# Base URL override (defaults to https://v3.football.api-sports.io)
# API_FOOTBALL_BASE_URL=

# Optional: comma-separated subset of curated league IDs (must be in src/lib/leagues/curated.ts).
# Omit to sync & display all curated competitions.
# SYNC_LEAGUE_IDS=39,140,78

# On Vercel, scheduled crons send x-vercel-cron: 1 (handled in code). For local/dev or other hosts, use:
# Authorization: Bearer <CRON_SECRET> or header x-cron-secret: <CRON_SECRET>
CRON_SECRET=change-me

# Public key for official API-SPORTS embed widgets (browser). Same value as API_FOOTBALL_KEY is typical.
# https://api-sports.io/documentation/widgets/v3
NEXT_PUBLIC_API_FOOTBALL_WIDGET_KEY=2f43432cff0b9c2c9c62768c58cf76cc

NEXT_PUBLIC_SITE_URL=http://localhost:3000
